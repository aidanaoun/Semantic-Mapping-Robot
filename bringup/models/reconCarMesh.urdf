<?xml version="1.0"?>
<robot name="recon_car_polygon">

  <link name="chassis">
    <inertial>
      <mass value="2.0"/>
      <inertia ixx="0.113" ixy="0.0" ixz="0.0" iyy="0.033" iyz="0.0" izz="0.133"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.8 0.4 0.2"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="purple">
        <color rgba="0 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.8 0.4 0.2"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
  </link>


  <link name="front_sensor">
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.00001" ixy="0.0" ixz="0.0" iyy="0.00001" iyz="0.0" izz="0.00001"/>
    </inertial>
    <visual>
      <geometry>
        <box size="0.025 0.025 0.025"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.03 0.03 0.03"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
  </link>


  <link name="rightWheel">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.00250" iyy="0.00132" izz="0.00132" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.04"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.1" length="0.04"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <surface>
      <friction>
        <ode>
          <mu>1.5</mu>
          <mu2>1.5</mu2>
        </ode>
      </friction>
    </surface>
    </collision>
  </link>

  <link name="leftWheel">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.00250" ixy="0.0" ixz="0.0" iyy="0.00132" iyz="0.0" izz="0.00132"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.04"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.1" length="0.04"/>
      </geometry>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    <surface>
      <friction>
        <ode>
          <mu>1.5</mu>
          <mu2>1.5</mu2>
          <slip1>0.05</slip1>
          <slip2>0.05</slip2>
        </ode>
      </friction>
    </surface>
    </collision>
  </link>

  <link name="frontWheel">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.002"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <sphere radius="0.1"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.1"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>

<surface>
      <friction>
        <ode>
          <mu>0.0000000001</mu>
          <mu2>0.0000000001</mu2>
          <slip1>0.05</slip1>
          <slip2>0.05</slip2>
        </ode>
      </friction>
    </surface>

    </collision>
  </link>

  <link name="backWheel">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.002" ixy="0.0" ixz="0.0" iyy="0.002" iyz="0.0" izz="0.002"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <sphere radius="0.1"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.1"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>

<surface>
      <friction>
        <ode>
          <mu>0.0000000001</mu>
          <mu2>0.0000000001</mu2>
          <slip1>0.05</slip1>
          <slip2>0.05</slip2>
        </ode>
      </friction>
    </surface>

    </collision>
  </link>


  <joint name="chassis_to_rightWheel" type="continuous">
    <parent link="chassis"/>
    <child link="rightWheel"/>
    <origin xyz="0.0 -0.22 -0.15" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.05"/>
  </joint>


  <joint name="chassis_to_leftWheel" type="continuous">
    <parent link="chassis"/>
    <child link="leftWheel"/>
    <origin xyz="0.0 0.22 -0.15" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.05"/>
  </joint>


<joint name="chassis_to_frontWheel" type="fixed">
  <parent link="chassis"/>
  <child link="frontWheel"/>
  <origin xyz="0.35 0 -0.15" rpy="0 0 0"/>
</joint>


<joint name="chassis_to_backWheel" type="fixed">
  <parent link="chassis"/>
  <child link="backWheel"/>
  <origin xyz="-0.35 0 -0.15" rpy="0 0 0"/>
</joint>


 <joint name="front_sensor_to_chassis" type="fixed">
  <parent link="chassis"/>
  <child link="front_sensor"/>
  <origin xyz="0.4125 0 0.125" rpy="0 0 0"/>
</joint>



<ros2_control name="reconCarSystem" type="system">     <!-- this tag is read by the resource manager -->
    <hardware>
      <plugin>custom_hardware/CustomHardwareInterface</plugin>
      <param name="serial_port">/dev/ttyACM0</param>
      <param name="baud_rate">115200</param>   <!-- INSERT NEWLY CREATED PLUGIN HERE -->
    </hardware>
    <joint name="chassis_to_leftWheel">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="chassis_to_rightWheel">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control> 


</robot>